# ============================================================
# IT-Bot — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# --- Database (pgvector) ---
DATABASE_URL=postgresql://itbot:CHANGEME@localhost:5432/itbot_kb

# --- Embedding Provider ---
# Options: azure_openai | bedrock | self_hosted
EMBEDDING_PROVIDER=azure_openai

# Azure OpenAI (if EMBEDDING_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# AWS Bedrock (if EMBEDDING_PROVIDER=bedrock)
AWS_REGION=us-east-1
# Uses IAM role by default; set keys only for local dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Self-hosted BGE (if EMBEDDING_PROVIDER=self_hosted)
BGE_MODEL_NAME=BAAI/bge-large-en-v1.5

# --- LLM Provider (OpenAI-compatible endpoint) ---
LLM_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/
LLM_API_KEY=
LLM_DEPLOYMENT=gpt-4o
LLM_API_VERSION=2024-02-01

# --- Confluence ---
CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_USERNAME=service-account@yourcompany.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=IT          # Restrict to IT space

# --- SharePoint ---
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_URL=https://yourcompany.sharepoint.com/sites/IT

# --- Ticketing System ---
# Set TICKET_PROVIDER to the system in use (e.g. servicenow | jira | freshservice)
TICKET_PROVIDER=servicenow
TICKET_BASE_URL=https://yourcompany.service-now.com
TICKET_API_USER=
TICKET_API_PASSWORD=
# For Jira:
# TICKET_BASE_URL=https://yourcompany.atlassian.net
# TICKET_API_TOKEN=

# --- Retrieval ---
RETRIEVAL_TOP_K=20               # candidates before reranking
RETRIEVAL_FINAL_TOP_N=5          # chunks passed to LLM after reranking
CONFIDENCE_THRESHOLD=0.6         # below this → disclaimer + auto-draft ticket
TICKET_MAX_AGE_DAYS=548          # ~18 months; discard older resolved tickets

# --- Reranker ---
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Security ---
API_SECRET_KEY=CHANGEME-USE-A-LONG-RANDOM-STRING
ALLOWED_ORIGINS=https://your-internal-domain.com

# --- Simulation mode ---
# Set to true to skip real Confluence/SharePoint/ticket connectors and use
# the sample documents in data/sample/ instead. For local testing only.
# USE_SAMPLE_DATA=false
